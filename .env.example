# =============================================================================
# Football Intelligence Dashboard - Environment Variables
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/football_intelligence
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/football_intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=football_intelligence

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- API-Football (api-sports.io) ---
API_FOOTBALL_KEY=677757d29a30bd0bf42a2e14bd43a17d
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# --- LLM Providers ---
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini  # openai or gemini

# --- WhatsApp (CallMeBot) ---
WHATSAPP_NUMBERS=5521997515328,552198119205
WHATSAPP_API_KEYS=apikey1,apikey2
CALLMEBOT_URL=https://api.callmebot.com/whatsapp.php

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_IDS=chat_id_1,chat_id_2

# --- Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com

# --- JWT Auth ---
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
